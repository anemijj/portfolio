# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# media pesada
materia/**/*.mov
materia/**/*.mp4
materia/**/*.bip
materia/**/*.exr

# Excepciones: videos same-origin necesarios para visores WebGL
# (releases.githubusercontent.com no sirve CORS headers → WebGL no puede
# usarlos como textura). Deben estar bajo 100 MB.
!materia/vr-1.mov
# Loop liviano del render del anillo (~770KB) usado en soma.html.
!materia/rosegold.mp4
# Videos de la web institucional de Soma (comprimidos a 1280px h264).
!materia/hero-web.mp4
!materia/soma/websoma-1.mp4
